# ============================================================
# REQUIRED — la app no arrancará sin estas variables
# ============================================================

# Clave secreta para firmar tokens JWT (mínimo 32 caracteres aleatorios)
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=reemplazar-con-clave-secreta-aleatoria-de-64-caracteres

# Base de datos: en local con SQLite podés omitir DATABASE_URL (default = archivo en backend/).
# Producción: Postgres u otro (ajustá la URL).
# DATABASE_URL=postgresql://usuario:password@host:5432/nombre_db

# URLs del frontend separadas por coma (sin barra final). En local incluí localhost y 127.0.0.1 si usás next dev --hostname 127.0.0.1
FRONTEND_URL=https://tu-dominio-analytics.com,https://tu-dominio-backoffice.com
# ejemplo local: http://localhost:3005,http://localhost:3006,http://127.0.0.1:3005,http://127.0.0.1:3006

# ============================================================
# USUARIOS INICIALES — requeridos en el primer deploy
# ============================================================

# Misma contraseña para admin y analista (recomendado en dev). Si está definida,
# se usa para ambos y se ignora ADMIN_PASSWORD / ANALYST_PASSWORD.
SEED_SHARED_PASSWORD=PlataformaDev2026!

ADMIN_USERNAME=nicolas
ANALYST_USERNAME=analyst

# Solo si NO usás SEED_SHARED_PASSWORD:
# ADMIN_PASSWORD=...
# ANALYST_PASSWORD=...

# ============================================================
# ENTORNO — controla comportamiento en producción
# ============================================================

# Establecer "production" en producción para activar:
# - Cookie secure=True (solo HTTPS)
# - Advertencias de SQLite
ENVIRONMENT=development

# ============================================================
# GOOGLE GEMINI (resumen IA en reportes — generateContent)
# ============================================================

# Clave de Google AI Studio (Create API key). También podés usar GOOGLE_API_KEY con el mismo valor.
GEMINI_API_KEY=
# GOOGLE_API_KEY=

# Modelo soportado por la API (si falla, listá modelos en AI Studio o la doc de modelos)
# GEMINI_MODEL=gemini-2.5-flash

# ============================================================
# ANTHROPIC API
# ============================================================

ANTHROPIC_API_KEY=sk-ant-...

# ============================================================
# EMAIL / SMTP (opcional — necesario para enviar reportes PDF)
# ============================================================

MAIL_USERNAME=tu_email@gmail.com
MAIL_PASSWORD=tu_app_password_de_gmail
MAIL_FROM=tu_email@gmail.com
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_FROM_NAME=UXR Social Reports

# --- Solo desarrollo local (evita error de arranque si no usás SMTP todavía) ---
# MAIL_USERNAME=dev@example.com
# MAIL_PASSWORD=dev-placeholder
# MAIL_FROM=dev@example.com
# MAIL_SERVER=localhost

# ============================================================
# JWT — opcional (valores por defecto recomendados para prod)
# ============================================================

ALGORITHM=HS256
# Duración del token en minutos (default: 480 = 8 horas)
ACCESS_TOKEN_EXPIRE_MINUTES=480
